---
import BaseLayout from '../../components/BaseLayout.astro';
import siteData from '../../data/site.json';
const { site, locations } = siteData;

export async function getStaticPaths() {
  const data = (await import('../../data/site.json')).default;
  return data.locations.map(loc => ({ params: { slug: loc.slug }, props: { loc } }));
}

interface Props { loc: typeof siteData.locations[number] }
const { loc } = Astro.props;

const pageUrl = new URL(`/locations/${loc.slug}`, site.url).toString();
const heroImage = (loc as any).heroImage;

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'ClothingStore',
  '@id': `${pageUrl}#store`,
  name: loc.fullName,
  parentOrganization: { '@type': 'Organization', name: site.name },
  url: pageUrl,
  telephone: loc.phone,
  image: heroImage ? new URL(heroImage, site.url).toString() : undefined,
  address: {
    '@type': 'PostalAddress',
    streetAddress: loc.streetAddress,
    addressLocality: loc.addressLocality,
    addressRegion: loc.addressRegion,
    postalCode: loc.postalCode,
    addressCountry: 'US',
  },
  geo: { '@type': 'GeoCoordinates', latitude: loc.geo.lat, longitude: loc.geo.lng },
  openingHoursSpecification: loc.openingHoursSpec.map((o: any) => ({
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: o.dayOfWeek,
    opens: o.opens,
    closes: o.closes,
  })),
  hasMap: loc.directionsUrl,
  sameAs: [site.instagramUrl, site.facebookUrl, site.amazonUrl].filter(Boolean),
};

const description = `${loc.addressLines.join(' ')}. ${loc.hours.join(' ')}. Phone ${loc.phone}.`;
const phoneTel = loc.phone.replace(/[^0-9+]/g, '');
const shareUrl = encodeURIComponent(pageUrl);
const shareText = encodeURIComponent(loc.fullName);
---
<BaseLayout
  title={`${loc.fullName} | Mandy+Ally`}
  description={description}
  ogImage={heroImage}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  </Fragment>

  <section class="page-banner">
    <h1>{loc.fullName}</h1>
  </section>

  <section class="loc-page">
    <div class="container">
      {heroImage ? (
        <img class="loc-hero-img" alt={loc.fullName} src={heroImage} />
      ) : (
        <div class="loc-hero-placeholder" aria-hidden="true"></div>
      )}

      <div class="loc-detail">
        <div>
          <h2 class="section-title">Store Location</h2>
          <div class="body-copy">
            <p set:html={loc.addressLines.join('<br>')} />
            <p><a class="phone-link" href={`tel:${phoneTel}`}>{loc.phone}</a></p>
          </div>
        </div>
        <div>
          <h2 class="section-title">Hours of Operation</h2>
          <div class="body-copy">
            <p set:html={loc.hours.join('<br>')} />
          </div>
        </div>
      </div>

      <h2 class="section-title" style="margin-top: 32px;">Map</h2>
      <div class="loc-map-wrap">
        <iframe
          src={loc.mapsEmbed}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
          title={`Map of ${loc.fullName}`}></iframe>
      </div>
      <a class="btn-outline" href={loc.directionsUrl} target="_blank" rel="noopener">Get Directions</a>

      <div class="share-row">
        <span>Share This Location</span>
        <a href={`https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`} target="_blank" rel="noopener" aria-label="Share on Facebook">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M13.5 22v-8h2.7l.4-3.2h-3.1V8.7c0-.9.3-1.6 1.6-1.6h1.6V4.2c-.3 0-1.3-.1-2.4-.1-2.4 0-4 1.4-4 4.1v2.6H7.6V14h2.7v8h3.2z"/></svg>
        </a>
        <a href={`https://twitter.com/intent/tweet?url=${shareUrl}&text=${shareText}`} target="_blank" rel="noopener" aria-label="Share on X / Twitter">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2H21l-6.52 7.45L22 22h-6.27l-4.9-6.42L5.2 22H2.44l6.98-7.98L2 2h6.4l4.43 5.86L18.24 2zm-1.1 18.18h1.74L7.94 3.72H6.1l11.04 16.46z"/></svg>
        </a>
        <a href={`mailto:?subject=${shareText}&body=Check%20out%20${shareText}%3A%20${shareUrl}`} aria-label="Share via email">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
