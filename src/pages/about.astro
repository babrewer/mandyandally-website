---
import BaseLayout from '../components/BaseLayout.astro';

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'About', href: '/about' },
];
---
<BaseLayout
  title="About | Mandy+Ally"
  description="The story behind Mandy + Ally — two longtime fashion buyers who left big retail to bring quality service and fun fashion to Savannah and Hilton Head."
  ogImage="/images/about-owners.jpeg"
  breadcrumbs={breadcrumbs}
>
  <section class="about about-page">
    <div class="container about-grid">
      <div class="about-text">
        <h1 class="about-h1">About Us</h1>
        <h2 class="about-sub">Mandy + Ally</h2>
        <div class="body-copy">
          <p>Mandy and I worked as buyers of a fast-paced fashion chain for 15 years. Playing off each other's strengths, we were very instrumental in growing that chain from 100 to over 400 stores. Traveling and buying all over the globe, we soon became fast friends. After our long productive careers buying for specialty stores, we decided to adapt to the new retail environment and created Mandy + Ally!</p>
          <p>Our goal is simple — offer Quality Customer Service and Fun Fashion at Great Price Points!!</p>
          <p>Life is too short not to enjoy every minute. That's what we strive to do every day. Thank you for shopping M+A!!</p>
        </div>
      </div>
      <div class="about-photo">
        <img src="/images/about-owners.jpeg" alt="Mandy and Ally, founders of Mandy + Ally" width="1080" height="1125" />
      </div>
    </div>
  </section>
</BaseLayout>
